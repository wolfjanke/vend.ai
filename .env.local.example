# Se qualquer segredo vazar (log, chat, repositório), rotacione imediatamente no Neon, Google AI e NextAuth.

# ─── Banco (Neon Postgres) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Local:
NEXTAUTH_URL=http://localhost:3000
# Produção (obrigatório): URL canónica com https, sem barra final — ex.: https://vendai.club
# NEXTAUTH_URL=https://vendai.club
# Obrigatório em produção (Vercel: Settings → Environment Variables). Sem isto o login mostra
# "There is a problem with the server configuration" em /api/auth/error.
# Podes usar AUTH_SECRET em alternativa — o código aceita qualquer um dos dois.
NEXTAUTH_SECRET=gere-um-segredo-longo-aleatorio

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Produção: https://vendai.club

# ─── Empresa (footer e documentos legais) ────────────────────────────────────
COMPANY_NAME=Wolf Hub Desenvolvimento de Software LTDA
COMPANY_CNPJ=67.038.423/0001-71
COMPANY_CITY=Curitiba - PR

# WhatsApp da loja demo Urban Mix (apenas para scripts de setup)
URBAN_MIX_WHATSAPP=5500000000000

# ─── Google Gemini (Vi + análise de produto) ─────────────────────────────────
GEMINI_API_KEY=
# Opcional — padrão: gemini-2.5-flash (veja modelos em https://ai.google.dev/gemini-api/docs/models)
# GEMINI_MODEL=gemini-2.5-flash

# ─── Asaas / Wolf Hub (conta mãe) ────────────────────────────────────────────
# sandbox | production
ASAAS_ENV=sandbox
WOLF_HUB_ASAAS_KEY=
WOLF_HUB_WALLET_ID=
VENDAI_ASAAS_WALLET_ID=

# Legado (fallback até migrar tudo para WOLF_HUB_ASAAS_KEY)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Webhook: header asaas-access-token (spec "ASAAS_WEBHOOK_SECRET" = mesmo valor)
ASAAS_WEBHOOK_TOKEN=

# Cron mensal — excedente Vi (header Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Criptografia da API key de subconta (32 bytes em base64). Gerar: openssl rand -base64 32
SUBACCOUNT_ENCRYPTION_KEY=

# ─── Cloudinary (upload assinado no admin — obrigatório para imagens em produção) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── E-mail (Resend — recuperação de senha) ──────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_bX4VZLhE_MdXoqRFoxkSwNFmQsAUBt4EM
# Remetente verificado no Resend, ex: vend.ai <noreply@seudominio.com>
EMAIL_FROM=vend.ai <onboarding@resend.dev>

# ─── Supabase (se usar storage legado) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Anthropic (legado / opcional) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
