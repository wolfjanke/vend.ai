# Se qualquer segredo vazar (log, chat, repositório), rotacione imediatamente no Neon, Google AI e NextAuth.

# ─── Banco (Neon Postgres) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Local:
NEXTAUTH_URL=http://localhost:3000
# Produção (obrigatório): URL canónica com https, sem barra final — ex.: https://vendai.club
# NEXTAUTH_URL=https://vendai.club
# Mesmo segredo em todos os deploys; sem isso /admin e sessão quebram com erro 500 em produção.
NEXTAUTH_SECRET=gere-um-segredo-longo-aleatorio

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google Gemini (Vi + análise de produto) ─────────────────────────────────
GEMINI_API_KEY=
# Opcional — padrão: gemini-2.5-flash (veja modelos em https://ai.google.dev/gemini-api/docs/models)
# GEMINI_MODEL=gemini-2.5-flash

# ─── Cloudinary (upload de imagens — opcional; sem isso usa base64) ─────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── E-mail (Resend — recuperação de senha) ──────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=
# Remetente verificado no Resend, ex: vend.ai <noreply@seudominio.com>
EMAIL_FROM=vend.ai <onboarding@resend.dev>

# ─── Supabase (se usar storage legado) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Anthropic (legado / opcional) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
