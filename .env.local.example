# Copie para .env.local e preencha os valores vazios.
# Se qualquer segredo vazar, rotacione no Neon, Google AI, NextAuth e Asaas.

# ─── Banco (Neon) ────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Login com Google (Google Cloud → Credenciais → OAuth 2.0 → Aplicativo da Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Superadmin (vendai.club/superadmin) ───────────────────────────────────────
SUPERADMIN_EMAILS=

# ─── Google Gemini (Vi + análise de produto) ─────────────────────────────────
GEMINI_API_KEY=

# ─── Cloudinary (upload de fotos no admin) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── E-mail (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=vend.ai <suporte@vendai.club>
EMAIL_REPLY_TO=

# Versão dos Termos de Uso aceita no cadastro (ex.: v1.1)
TERMS_VERSION=v1.1

# WhatsApp do fundador (fluxo de retenção no cancelamento — /admin/plano)
FOUNDER_WHATSAPP=5565999883143

# ─── Asaas PRODUÇÃO (assinatura de planos) ───────────────────────────────────
# Painel: https://www.asaas.com → Integrações → API
VENDAI_ASAAS_KEY=
# Wallet: GET https://api.asaas.com/v3/wallets (header access_token)
VENDAI_ASAAS_WALLET_ID=
# Webhook: https://vendai.club/api/webhooks/asaas (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=production

# Criptografia de subcontas — gerar uma vez: openssl rand -base64 32
# Mesmo valor em local e Vercel; não trocar após lojas com onboarding
SUBACCOUNT_ENCRYPTION_KEY=

# ─── Rate limit distribuído (recomendado em produção para login e APIs) ───────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
